{
    "feat_gen": {
        "feature_generator": "CNNIDSFeatureGenerator",
        "config": {
            "window_size": 44,
            "window_slide": 1,
            "number_of_bytes": 58,
            "multiclass": true,
            "labeling_schema": "TOW_IDS_dataset_multi_class",
            "dataset": "TOW_IDS_dataset"
        },
        "load_paths": {
            "X_path": "sample_inputs/sample_input_network_traffic_imaging.npz",
            "y_path": "sample_inputs/sample_label_multiclass_tow.csv"
        }
    },
    "model_specs": {
        "framework": "pytorch",
        "model": "PrunedCNNIDS",
        "model_name": "PrunedCNNIDS",
        "criterion": "categorical-cross-entropy",
        "hyperparameters": {
            "batch_size": 64,
            "learning_rate": 0.001,
            "num_epochs": 1,
            "early_stopping_patience": 5,
            "num_outputs": 6
        },
        "paths": {
            "metrics_output_path":"/content/metrics",
            "models_output_path":"/content/models",
            "forward_output_path":"/content/forward"
        },
        "presaved_paths": {
            "0": "trained_models/TOW/second_stage/TOW_MC_pytorch_model_PrunedCNNIDS_0_our",
            "1": "trained_models/TOW/second_stage/TOW_MC_pytorch_model_PrunedCNNIDS_1_our",
            "2": "trained_models/TOW/second_stage/TOW_MC_pytorch_model_PrunedCNNIDS_2_our",
            "3": "trained_models/TOW/second_stage/TOW_MC_pytorch_model_PrunedCNNIDS_3_our",
            "4": "trained_models/TOW/second_stage/TOW_MC_pytorch_model_PrunedCNNIDS_4_our"
        }
    }
}
