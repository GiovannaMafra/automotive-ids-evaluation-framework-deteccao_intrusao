{
    "feat_gen": {
        "feature_generator": "CNNIDSFeatureGenerator",
        "config": {
            "window_size": 44,
            "window_slide": 1,
            "number_of_bytes": 58,
            "multiclass": false,
            "labeling_schema": "TOW_IDS_dataset_multi_class",
            "dataset": "TOW_IDS_dataset",
            "sum_x": true
        },
        "load_paths": {
            "X_path": "sample_inputs/sample_input_sum_aggregated.npz",
            "y_path": "sample_inputs/sample_label_one_class_tow.csv"
        }
    },
    "model_specs": {
        "framework": "sklearn",
        "model": "SklearnClassifier",
        "model_name": "IsolationForest",
        "model_params": {
            "n_estimators": 200,
            "contamination": 0.05, 
            "random_state": 42
        },
        "paths": {
            "metrics_output_path":"metrics",
            "models_output_path":"models"
        }
    }
}